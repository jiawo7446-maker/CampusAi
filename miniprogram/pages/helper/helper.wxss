.page {
  min-height: 100vh;
  background-color: #f9f5ff;
}

.content {
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

/* ===== 统计栏 ===== */
.stats-row {
  display: flex;
  flex-direction: row;
  gap: 32rpx;
}

.stat-card {
  flex: 1;
  background-color: rgba(36, 68, 235, 0.05);
  border: 2rpx solid rgba(36, 68, 235, 0.05);
  border-radius: 16rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  font-weight: 700;
  color: #2444eb;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.stat-value-row {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  gap: 4rpx;
}

.stat-num {
  font-size: 60rpx;
  font-weight: 800;
  color: #2444eb;
  line-height: 1;
}

.stat-unit {
  font-size: 28rpx;
  color: rgba(36, 68, 235, 0.6);
  margin-bottom: 6rpx;
}

.stat-badge {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  margin-top: 8rpx;
}

.pulse-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 9999rpx;
  background-color: #0c6a24;
}

.stat-zap {
  width: 24rpx;
  height: 24rpx;
  flex-shrink: 0;
}

.stat-badge-text {
  font-size: 20rpx;
  font-weight: 500;
  color: #0c6a24;
}

.stat-badge-text--primary {
  color: #2444eb;
}

/* ===== 列表标题 ===== */
.list-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: flex-end;
}

.urgent-filter-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.urgent-toggle {
  display: flex;
  align-items: center;
  padding: 10rpx 22rpx;
  border-radius: 9999rpx;
  background-color: #f3eeff;
  border: 2rpx solid rgba(172, 168, 215, 0.3);
}

.urgent-toggle--active {
  background-color: #fef3c7;
  border-color: #f59e0b;
}

.urgent-toggle-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #5a5781;
}

.urgent-toggle--active .urgent-toggle-text {
  color: #b45309;
}

.urgent-empty {
  padding: 32rpx;
  text-align: center;
}

.urgent-empty-text {
  font-size: 28rpx;
  color: #75729e;
}

.list-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #2d2a51;
  letter-spacing: -1rpx;
}

.list-sub {
  display: block;
  font-size: 28rpx;
  color: #5a5781;
  margin-top: 4rpx;
}

.btn-tag {
  font-size: 24rpx;
  font-weight: 700;
  color: #2444eb;
  padding: 8rpx 24rpx;
  background-color: rgba(36, 68, 235, 0.1);
  border-radius: 9999rpx;
  white-space: nowrap;
}

/* ===== 任务列表滚动容器 ===== */
.task-list-scroll {
  height: 680rpx;
  overflow: hidden;
  border-radius: 16rpx;
  -webkit-mask-image: linear-gradient(to bottom, black 85%, transparent 100%);
  mask-image: linear-gradient(to bottom, black 85%, transparent 100%);
}

/* ===== 任务卡片 ===== */
.task-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding-bottom: 32rpx;
}

.task-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 40rpx rgba(45, 42, 81, 0.03);
  border: 2rpx solid rgba(36, 68, 235, 0.05);
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
}

.task-card-hover {
  background-color: #f3eeff;
  opacity: 0.9;
}

.task-avatar-wrap {
  position: relative;
  flex-shrink: 0;
}

.task-avatar-circle {
  width: 96rpx;
  height: 96rpx;
  border-radius: 9999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.task-avatar-initial {
  font-size: 36rpx;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.95);
  line-height: 1;
}

.task-icon-badge {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 9999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #ffffff;
}

.task-icon-badge--primary   { background-color: #2444eb; }
.task-icon-badge--secondary { background-color: #8a4c00; }
.task-icon-badge--tertiary  { background-color: #0c6a24; }

.task-icon-badge-svg {
  width: 20rpx;
  height: 20rpx;
}

.task-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.task-top-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: flex-start;
}

.task-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #2d2a51;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.task-tag {
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.task-tag-text {
  font-size: 20rpx;
  font-weight: 700;
}

.task-tag--primary   { background-color: rgba(36, 68, 235, 0.1); }
.task-tag--primary .task-tag-text { color: #2444eb; }
.task-tag--secondary { background-color: rgba(138, 76, 0, 0.1); }
.task-tag--secondary .task-tag-text { color: #8a4c00; }
.task-tag--tertiary  { background-color: rgba(12, 106, 36, 0.1); }
.task-tag--tertiary .task-tag-text { color: #0c6a24; }

.task-desc {
  display: block;
  font-size: 26rpx;
  color: #5a5781;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-top: 4rpx;
}

.task-meta-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  margin-top: 8rpx;
}

.task-location {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 6rpx;
}

.task-location-icon {
  width: 20rpx;
  height: 20rpx;
  flex-shrink: 0;
}

.task-location-text {
  font-size: 20rpx;
  color: #2444eb;
  font-weight: 500;
}

.task-time {
  font-size: 20rpx;
  color: rgba(90, 87, 129, 0.6);
}

.task-reward-row {
  margin-top: 8rpx;
}

.task-reward-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #d97706;
  background-color: #fef9e7;
  padding: 4rpx 16rpx;
  border-radius: 9999rpx;
  display: inline-block;
}

.btn-accept {
  background-color: #2444eb;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  padding: 16rpx 32rpx;
  border-radius: 9999rpx;
  white-space: nowrap;
  flex-shrink: 0;
  transition: opacity 0.2s;
}

.btn-accept--done {
  background-color: #0c6a24;
}

/* ===== 发布任务弹窗 ===== */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background-color: rgba(45, 42, 81, 0.5);
  z-index: 9999;
  display: flex;
  align-items: flex-end;
}

.modal-sheet {
  width: 100%;
  background-color: #ffffff;
  border-top-left-radius: 48rpx;
  border-top-right-radius: 48rpx;
  padding: 48rpx 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.modal-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #2d2a51;
  text-align: center;
}

.modal-label {
  font-size: 24rpx;
  font-weight: 700;
  color: #5a5781;
  margin-bottom: 12rpx;
  display: block;
}

.modal-label-hint {
  font-size: 22rpx;
  font-weight: 400;
  color: rgba(90, 87, 129, 0.6);
}

.type-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
}

.type-chip {
  padding: 12rpx 28rpx;
  border-radius: 9999rpx;
  background-color: #eae5ff;
  font-size: 24rpx;
  font-weight: 600;
  color: #5a5781;
}

.type-chip--active {
  background-color: #2444eb;
  color: #ffffff;
}

.modal-textarea {
  width: 100%;
  background-color: #f3eeff;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #2d2a51;
  min-height: 120rpx;
  box-sizing: border-box;
}

.modal-input {
  width: 100%;
  background-color: #f3eeff;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #2d2a51;
  box-sizing: border-box;
  height: 88rpx;
  line-height: 88rpx;
  display: block;
}

.modal-actions {
  display: flex;
  flex-direction: row;
  gap: 24rpx;
}

.btn-cancel {
  flex: 1;
  background-color: #eae5ff;
  color: #5a5781;
  font-size: 28rpx;
  font-weight: 700;
  padding: 28rpx;
  border-radius: 9999rpx;
  text-align: center;
}

.btn-submit {
  flex: 2;
  background-color: #2444eb;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  padding: 28rpx;
  border-radius: 9999rpx;
  text-align: center;
  box-shadow: 0 8rpx 20rpx rgba(36, 68, 235, 0.2);
}

/* ===== 已接受任务 ===== */
.accepted-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.accepted-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #2d2a51;
}

.accepted-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.accepted-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx 24rpx;
  border: 2rpx solid rgba(12, 106, 36, 0.15);
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.accepted-card__header {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.accepted-card__body {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.accepted-card__left {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.accepted-tag {
  width: 56rpx;
  height: 56rpx;
  border-radius: 9999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.accepted-tag--primary   { background-color: rgba(36, 68, 235, 0.12); }
.accepted-tag--secondary { background-color: rgba(138, 76, 0, 0.12); }
.accepted-tag--tertiary  { background-color: rgba(12, 106, 36, 0.12); }

.accepted-tag__icon {
  width: 28rpx;
  height: 28rpx;
}

.accepted-card__info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.accepted-card__name {
  font-size: 28rpx;
  font-weight: 700;
  color: #2d2a51;
}

.accepted-card__desc {
  font-size: 24rpx;
  color: #5a5781;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.accepted-badge {
  font-size: 20rpx;
  font-weight: 700;
  padding: 6rpx 18rpx;
  border-radius: 9999rpx;
  white-space: nowrap;
}

.accepted-badge--active {
  color: #16a34a;
  background-color: rgba(22, 163, 74, 0.1);
}

.accepted-badge--done {
  color: #9ca3af;
  background-color: rgba(156, 163, 175, 0.12);
}

.btn-complete {
  flex-shrink: 0;
  font-size: 26rpx;
  font-weight: 700;
  color: #ffffff;
  background-color: #2444eb;
  padding: 18rpx 36rpx;
  border-radius: 14rpx;
  white-space: nowrap;
  text-align: center;
}

.btn-complete--done {
  background-color: #e5e7eb;
  color: #9ca3af;
}

/* ===== 任务详情弹窗 ===== */
.detail-sheet {
  max-height: 80vh;
  overflow-y: auto;
}

.detail-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 8rpx;
}

.detail-avatar-wrap {
  position: relative;
  flex-shrink: 0;
}

.detail-avatar-circle {
  width: 112rpx;
  height: 112rpx;
  border-radius: 9999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-avatar-initial {
  font-size: 48rpx;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.95);
  line-height: 1;
}

.detail-header__info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.detail-name {
  font-size: 36rpx;
  font-weight: 800;
  color: #2d2a51;
}

.detail-divider {
  height: 2rpx;
  background-color: #eae5ff;
  margin: 8rpx 0 24rpx;
}

.detail-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 24rpx;
}

.detail-label {
  font-size: 22rpx;
  font-weight: 700;
  color: #5a5781;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.detail-value {
  font-size: 28rpx;
  color: #2d2a51;
  line-height: 1.6;
}

.detail-time {
  color: rgba(90, 87, 129, 0.7);
}

.detail-reward {
  color: #0c6a24;
  font-weight: 700;
}

.detail-actions {
  display: flex;
  flex-direction: row;
  gap: 24rpx;
  margin-top: 8rpx;
}

.btn-submit--done {
  background-color: #0c6a24;
}

/* ===== 发布横幅 ===== */
.publish-banner {
  background: linear-gradient(135deg, #2444eb, #8999ff);
  border-radius: 24rpx;
  padding: 48rpx;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  overflow: hidden;
}

.publish-banner__text {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.publish-banner__title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
}

.publish-banner__sub {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  max-width: 360rpx;
}

.btn-publish {
  align-self: flex-start;
  margin-top: 32rpx;
  background-color: #ffffff;
  color: #2444eb;
  font-size: 24rpx;
  font-weight: 800;
  padding: 16rpx 40rpx;
  border-radius: 9999rpx;
}

.btn-publish-hover {
  opacity: 0.75;
}

.publish-banner__icon {
  width: 160rpx;
  height: 160rpx;
  opacity: 0.2;
  flex-shrink: 0;
}
