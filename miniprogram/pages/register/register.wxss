.page {
  min-height: 100vh;
  background-color: #f9f5ff;
  display: flex;
  flex-direction: column;
}

/* ===== 顶部 ===== */
.reg-hero {
  position: relative;
  background: linear-gradient(145deg, #2444eb 0%, #8999ff 100%);
  padding: 80rpx 48rpx 96rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.hero-blob {
  position: absolute;
  border-radius: 9999rpx;
  opacity: 0.15;
}

.hero-blob--1 {
  width: 350rpx;
  height: 350rpx;
  background-color: #ffffff;
  top: -100rpx;
  right: -60rpx;
}

.hero-blob--2 {
  width: 200rpx;
  height: 200rpx;
  background-color: #ffffff;
  bottom: -50rpx;
  left: 60rpx;
}

.back-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 9999rpx;
  margin-bottom: 32rpx;
}

.back-btn-hover {
  background-color: rgba(255, 255, 255, 0.35);
}

.back-icon {
  width: 40rpx;
  height: 40rpx;
}

.hero-title {
  display: block;
  font-size: 56rpx;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: -1rpx;
}

.hero-sub {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

/* ===== 表单卡片 ===== */
.reg-card {
  flex: 1;
  background-color: #ffffff;
  border-top-left-radius: 48rpx;
  border-top-right-radius: 48rpx;
  margin-top: -40rpx;
  padding: 48rpx 48rpx 64rpx;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -8rpx 40rpx rgba(45, 42, 81, 0.06);
}

/* ===== 输入框（复用 login 风格）===== */
.input-group {
  margin-bottom: 28rpx;
}

.input-label {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #5a5781;
  margin-bottom: 10rpx;
  letter-spacing: 1rpx;
}

.input-wrap {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #f3eeff;
  border-radius: 16rpx;
  padding: 0 24rpx;
  height: 96rpx;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.input-wrap--focused {
  border-color: #2444eb;
  background-color: #eee9ff;
}

.input-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
  margin-right: 16rpx;
  opacity: 0.6;
}

.input-field {
  flex: 1;
  font-size: 28rpx;
  color: #2d2a51;
  height: 96rpx;
  line-height: 96rpx;
}

.input-placeholder {
  color: rgba(90, 87, 129, 0.45);
}

.pwd-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  flex-shrink: 0;
  border-radius: 9999rpx;
}

.pwd-toggle-hover {
  background-color: rgba(36, 68, 235, 0.08);
}

.pwd-toggle-icon {
  width: 40rpx;
  height: 40rpx;
}

/* ===== 密码强度 ===== */
.pwd-strength {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  margin-top: -12rpx;
  margin-bottom: 24rpx;
}

.strength-bar {
  flex: 1;
  height: 8rpx;
  background-color: #eae5ff;
  border-radius: 9999rpx;
  overflow: hidden;
}

.strength-fill {
  height: 100%;
  border-radius: 9999rpx;
  transition: width 0.3s;
}

.strength-fill--weak   { background-color: #ef4444; }
.strength-fill--medium { background-color: #f59e0b; }
.strength-fill--strong { background-color: #0c6a24; }

.strength-text {
  font-size: 22rpx;
  font-weight: 600;
  white-space: nowrap;
}

.strength-text--weak   { color: #ef4444; }
.strength-text--medium { color: #f59e0b; }
.strength-text--strong { color: #0c6a24; }

/* ===== 协议 ===== */
.terms-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-wrap: wrap;
  gap: 4rpx;
  margin-bottom: 32rpx;
}

.terms-check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 8rpx;
  border: 2rpx solid #aca8d7;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.terms-check--active {
  background-color: #2444eb;
  border-color: #2444eb;
}

.terms-check__mark {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 700;
}

.terms-text {
  font-size: 24rpx;
  color: #5a5781;
}

.terms-link {
  font-size: 24rpx;
  color: #2444eb;
  font-weight: 600;
}

/* ===== 注册按钮 ===== */
.btn-register {
  background: linear-gradient(135deg, #2444eb, #5566f8);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
  padding: 32rpx;
  border-radius: 9999rpx;
  box-shadow: 0 12rpx 32rpx rgba(36, 68, 235, 0.25);
  letter-spacing: 2rpx;
}

.btn-register--loading {
  opacity: 0.7;
}

/* ===== 返回登录 ===== */
.login-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 36rpx;
}

.login-text {
  font-size: 26rpx;
  color: #5a5781;
}

.login-link {
  font-size: 26rpx;
  font-weight: 700;
  color: #2444eb;
}
