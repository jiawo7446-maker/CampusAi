.page {
  min-height: 100vh;
  background-color: #f9f5ff;
  display: flex;
  flex-direction: column;
}

/* ===== 顶部英雄区 ===== */
.login-hero {
  position: relative;
  background: linear-gradient(145deg, #2444eb 0%, #5566f8 60%, #8999ff 100%);
  padding: 72rpx 48rpx 108rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  overflow: hidden;
}

.hero-blob {
  position: absolute;
  border-radius: 9999rpx;
}

.hero-blob--1 {
  width: 460rpx;
  height: 460rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.12) 0%, transparent 70%);
  top: -160rpx;
  right: -100rpx;
}

.hero-blob--2 {
  width: 280rpx;
  height: 280rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.10) 0%, transparent 70%);
  bottom: -80rpx;
  left: -40rpx;
}

.hero-blob--3 {
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, transparent 70%);
  top: 40rpx;
  left: 20rpx;
}

/* Logo区 */
.hero-logo-wrap {
  position: relative;
  margin-bottom: 28rpx;
}

.hero-logo-ring {
  width: 152rpx;
  height: 152rpx;
  border-radius: 9999rpx;
  border: 3rpx solid rgba(255,255,255,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 40rpx rgba(255,255,255,0.15);
}

.hero-logo-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 9999rpx;
  background: rgba(255,255,255,0.22);
  border: 3rpx solid rgba(255,255,255,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-logo-icon {
  width: 68rpx;
  height: 68rpx;
}

.hero-ai-badge {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  background: linear-gradient(135deg, #3d7fff, #2444eb);
  border-radius: 9999rpx;
  padding: 4rpx 14rpx;
  border: 3rpx solid #fff;
}

.hero-ai-badge-text {
  font-size: 20rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 1rpx;
}

.hero-app-name {
  display: block;
  font-size: 46rpx;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: 0rpx;
  text-shadow: 0 2rpx 12rpx rgba(0,0,0,0.15);
}

.hero-slogan {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.82);
  margin-top: 10rpx;
  margin-bottom: 32rpx;
}

/* 功能 chips */
.hero-chips {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: center;
  gap: 16rpx;
}

.hero-chip {
  background: rgba(255,255,255,0.18);
  border: 1rpx solid rgba(255,255,255,0.35);
  border-radius: 9999rpx;
  padding: 8rpx 20rpx;
  font-size: 22rpx;
  color: rgba(255,255,255,0.92);
}

/* ===== 登录卡片 ===== */
.login-card {
  flex: 1;
  background-color: #ffffff;
  border-top-left-radius: 52rpx;
  border-top-right-radius: 52rpx;
  margin-top: -44rpx;
  padding: 52rpx 44rpx 60rpx;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -8rpx 40rpx rgba(45,42,81,0.08);
}

.card-title {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  color: #2d2a51;
  letter-spacing: -1rpx;
}

.card-sub {
  display: block;
  font-size: 27rpx;
  color: #5a5781;
  margin-top: 8rpx;
  margin-bottom: 44rpx;
}

/* ===== 输入框 ===== */
.input-group {
  margin-bottom: 28rpx;
}

.input-label {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #5a5781;
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
}

.input-wrap {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #f3eeff;
  border-radius: 20rpx;
  padding: 0 24rpx;
  height: 100rpx;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.input-wrap--focused {
  border-color: #2444eb;
  background-color: #eee9ff;
  box-shadow: 0 0 0 6rpx rgba(36,68,235,0.08);
}

.input-icon {
  width: 38rpx;
  height: 38rpx;
  flex-shrink: 0;
  margin-right: 18rpx;
  opacity: 0.55;
}

.input-field {
  flex: 1;
  font-size: 30rpx;
  color: #2d2a51;
  height: 100rpx;
  line-height: 100rpx;
}

.input-placeholder {
  color: rgba(90,87,129,0.4);
}

.pwd-toggle {
  padding: 8rpx 0 8rpx 16rpx;
  flex-shrink: 0;
}

.pwd-toggle-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #2444eb;
}

/* ===== 登录按钮 ===== */
.btn-login {
  background: linear-gradient(135deg, #2444eb 0%, #5566f8 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
  padding: 34rpx;
  border-radius: 9999rpx;
  margin-top: 20rpx;
  box-shadow: 0 12rpx 32rpx rgba(36,68,235,0.28);
  letter-spacing: 3rpx;
}

.btn-login--loading {
  opacity: 0.65;
}

.btn-login-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
}

/* 安全提示 */
.security-note {
  text-align: center;
  margin-top: 16rpx;
  margin-bottom: 4rpx;
}

.security-text {
  font-size: 22rpx;
  color: rgba(90,87,129,0.5);
}

/* ===== 底部链接 ===== */
.bottom-links {
  margin-top: auto;
  padding-top: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
}

.register-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.register-text {
  font-size: 27rpx;
  color: #5a5781;
}

.register-link {
  font-size: 27rpx;
  font-weight: 700;
  color: #2444eb;
}

.link-sep {
  width: 60rpx;
  height: 2rpx;
  background: #eae5ff;
  margin: 20rpx 0;
}

.guest-link {
  text-align: center;
}

.guest-text {
  font-size: 24rpx;
  color: rgba(90,87,129,0.55);
}
