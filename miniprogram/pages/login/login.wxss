.page {
  min-height: 100vh;
  background-color: #f9f5ff;
  display: flex;
  flex-direction: column;
}

/* ===== 顶部英雄区 ===== */
.login-hero {
  position: relative;
  background: linear-gradient(160deg, #1630c8 0%, #2f4ef5 45%, #6a3fef 100%);
  padding: 72rpx 44rpx 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  overflow: hidden;
}

.hero-blob {
  position: absolute;
  border-radius: 9999rpx;
}

.hero-blob--1 {
  width: 520rpx;
  height: 520rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.14) 0%, transparent 65%);
  top: -180rpx;
  right: -120rpx;
}

.hero-blob--2 {
  width: 320rpx;
  height: 320rpx;
  background: radial-gradient(circle, rgba(120,80,255,0.25) 0%, transparent 70%);
  bottom: -60rpx;
  left: -60rpx;
}

.hero-blob--3 {
  width: 180rpx;
  height: 180rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.10) 0%, transparent 70%);
  top: 60rpx;
  left: 30rpx;
}

.hero-blob--4 {
  width: 240rpx;
  height: 240rpx;
  background: radial-gradient(circle, rgba(100,60,255,0.18) 0%, transparent 70%);
  bottom: 30rpx;
  right: -60rpx;
}

/* Logo区 */
.hero-logo-wrap {
  position: relative;
  margin-bottom: 28rpx;
}

.hero-logo-ring {
  width: 160rpx;
  height: 160rpx;
  border-radius: 9999rpx;
  border: 2rpx solid rgba(255,255,255,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 0 16rpx rgba(255,255,255,0.06), 0 16rpx 48rpx rgba(0,0,0,0.2);
}

.hero-logo-circle {
  width: 124rpx;
  height: 124rpx;
  border-radius: 9999rpx;
  background: rgba(255,255,255,0.2);
  border: 2rpx solid rgba(255,255,255,0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 2rpx 8rpx rgba(255,255,255,0.15);
}

.hero-logo-icon {
  width: 72rpx;
  height: 72rpx;
}

.hero-ai-badge {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  background: linear-gradient(135deg, #3d7fff, #2444eb);
  border-radius: 9999rpx;
  padding: 4rpx 14rpx;
  border: 3rpx solid #fff;
}

.hero-ai-badge-text {
  font-size: 20rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 1rpx;
}

.hero-app-name {
  display: block;
  font-size: 50rpx;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: 1rpx;
  text-shadow: 0 4rpx 20rpx rgba(0,0,0,0.2);
}

.hero-slogan {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.72);
  margin-top: 12rpx;
  margin-bottom: 40rpx;
  letter-spacing: 2rpx;
}

/* ===== 数据统计行 ===== */
.hero-stats {
  display: flex;
  flex-direction: row;
  align-items: center;
  width: 100%;
  background: rgba(255,255,255,0.13);
  border: 1rpx solid rgba(255,255,255,0.22);
  border-radius: 28rpx;
  padding: 28rpx 0;
  box-sizing: border-box;
}

.hero-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.hero-stat-num {
  font-size: 48rpx;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: -1rpx;
  line-height: 1;
}

.hero-stat-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.65);
  font-weight: 500;
  letter-spacing: 1rpx;
}

.hero-stat-sep {
  width: 2rpx;
  height: 56rpx;
  background: rgba(255,255,255,0.2);
  flex-shrink: 0;
}

/* ===== 登录卡片 ===== */
.login-card {
  flex: 1;
  background-color: #ffffff;
  border-top-left-radius: 56rpx;
  border-top-right-radius: 56rpx;
  margin-top: -52rpx;
  padding: 56rpx 48rpx 64rpx;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -12rpx 60rpx rgba(36,44,140,0.10);
}

.card-title {
  display: block;
  font-size: 52rpx;
  font-weight: 800;
  color: #1a1740;
  letter-spacing: -1rpx;
}

.card-sub {
  display: block;
  font-size: 27rpx;
  color: #7c78a8;
  margin-top: 10rpx;
  margin-bottom: 48rpx;
}

/* ===== 输入框 ===== */
.input-group {
  margin-bottom: 28rpx;
}

.input-label {
  display: block;
  font-size: 23rpx;
  font-weight: 700;
  color: #4a4770;
  margin-bottom: 14rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.input-wrap {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #fafafe;
  border-radius: 20rpx;
  padding: 0 28rpx;
  height: 104rpx;
  border: 2rpx solid #e8e4f5;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(90,87,129,0.04);
}

.input-wrap--focused {
  border-color: #2444eb;
  background-color: #f8f7ff;
  box-shadow: 0 0 0 6rpx rgba(36,68,235,0.09);
}

.input-icon {
  width: 38rpx;
  height: 38rpx;
  flex-shrink: 0;
  margin-right: 18rpx;
  opacity: 0.55;
}

.input-field {
  flex: 1;
  font-size: 30rpx;
  color: #2d2a51;
  height: 100rpx;
  line-height: 100rpx;
}

.input-placeholder {
  color: rgba(90,87,129,0.4);
}

.pwd-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  flex-shrink: 0;
  border-radius: 9999rpx;
}

.pwd-toggle-hover {
  background-color: rgba(36, 68, 235, 0.08);
}

.pwd-toggle-icon {
  width: 40rpx;
  height: 40rpx;
}

/* ===== 登录按钮 ===== */
.btn-login {
  background: linear-gradient(135deg, #1e38dc 0%, #4a5ef7 60%, #6a52f5 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
  padding: 36rpx;
  border-radius: 9999rpx;
  margin-top: 28rpx;
  box-shadow: 0 16rpx 48rpx rgba(36,68,235,0.35), inset 0 1rpx 0 rgba(255,255,255,0.2);
  letter-spacing: 4rpx;
}

.btn-login--hover {
  opacity: 0.88;
  transform: scale(0.988);
}

.btn-login--loading {
  opacity: 0.6;
}

.btn-login-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}

/* 安全提示 */
.security-note {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 20rpx;
  margin-bottom: 4rpx;
}

.security-icon {
  font-size: 22rpx;
}

.security-text {
  font-size: 22rpx;
  color: rgba(90,87,129,0.45);
}

/* ===== 底部链接 ===== */
.bottom-links {
  margin-top: auto;
  padding-top: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
}

.register-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.register-text {
  font-size: 27rpx;
  color: #5a5781;
}

.register-link {
  font-size: 27rpx;
  font-weight: 700;
  color: #2444eb;
  border-bottom: 2rpx solid rgba(36,68,235,0.3);
  padding-bottom: 2rpx;
}

.link-sep {
  width: 60rpx;
  height: 2rpx;
  background: #eae5ff;
  margin: 20rpx 0;
}

.guest-link {
  text-align: center;
}

.guest-text {
  font-size: 24rpx;
  color: rgba(90,87,129,0.5);
  letter-spacing: 1rpx;
}
