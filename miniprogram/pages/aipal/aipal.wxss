.page {
  height: 100vh;
  background-color: #f9f5ff;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* ===== AI 状态栏 ===== */
.ai-topbar {
  margin: 0 32rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(36, 68, 235, 0.08);
  border: 2rpx solid rgba(172, 168, 215, 0.2);
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  flex-shrink: 0;
}

.ai-topbar__left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
}

.ai-topbar__avatar-wrap {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  border-radius: 9999rpx;
  background-color: #e3dfff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ai-topbar__bot-icon {
  width: 44rpx;
  height: 44rpx;
}

.ai-topbar__online-dot {
  position: absolute;
  bottom: 2rpx;
  right: 2rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 9999rpx;
  background-color: #22c55e;
  border: 3rpx solid #ffffff;
}

.ai-topbar__labels {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.ai-topbar__name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #2d2a51;
}

.ai-topbar__sub {
  display: block;
  font-size: 24rpx;
  color: #22c55e;
  font-weight: 500;
}

.ai-topbar__right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.ai-topbar__greeting {
  font-size: 26rpx;
  font-weight: 600;
  color: #4f46e5;
  max-width: 240rpx;
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ai-topbar__clear {
  background: rgba(99, 102, 241, 0.08);
  border-radius: 9999rpx;
  padding: 6rpx 20rpx;
}

.ai-topbar__clear--hover {
  opacity: 0.6;
}

.ai-topbar__clear-text {
  font-size: 22rpx;
  color: #6366f1;
  font-weight: 500;
}

/* ===== AI 每日建议卡 ===== */
.daily-card {
  margin: 0 0 16rpx;
  background: linear-gradient(135deg, #2444eb 0%, #5566f8 100%);
  border-radius: 24rpx;
  padding: 28rpx 32rpx 20rpx;
  box-shadow: 0 12rpx 36rpx rgba(36, 68, 235, 0.25);
}

.daily-card__header {
  margin-bottom: 14rpx;
}

.daily-card__tag {
  font-size: 22rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.85);
  background-color: rgba(255, 255, 255, 0.18);
  padding: 6rpx 18rpx;
  border-radius: 9999rpx;
}

.daily-card__text {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  line-height: 1.7;
  letter-spacing: 0.5rpx;
}

.daily-card__skeleton {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 4rpx 0 8rpx;
}

.skeleton-line {
  height: 24rpx;
  border-radius: 9999rpx;
  background-color: rgba(255, 255, 255, 0.25);
  animation: shimmer 1.4s infinite;
}

.skeleton-line--long  { width: 90%; }
.skeleton-line--short { width: 55%; }

@keyframes shimmer {
  0%, 100% { opacity: 0.4; }
  50%       { opacity: 0.9; }
}

.daily-card__footer {
  margin-top: 16rpx;
  display: flex;
  justify-content: flex-end;
}

.daily-card__footer-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
  font-weight: 600;
}

/* ===== 情绪快选 ===== */
.mood-bar {
  margin: 0 0 16rpx;
}

.mood-bar-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #5a5781;
  display: block;
  margin-bottom: 12rpx;
}

.mood-scroll {
  display: flex;
  flex-direction: row;
  white-space: nowrap;
  gap: 12rpx;
}

.mood-chip {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  border-radius: 9999rpx;
  background-color: #f3eeff;
  border: 2rpx solid rgba(172, 168, 215, 0.3);
  flex-shrink: 0;
  margin-right: 12rpx;
}

.mood-chip-emoji {
  font-size: 28rpx;
  line-height: 1;
}

.mood-chip-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #2d2a51;
}

/* ===== 今日课程小卡 ===== */
.course-widget {
  margin: 0 0 8rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(36, 68, 235, 0.07);
  border: 2rpx solid rgba(172, 168, 215, 0.15);
}

.course-widget-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.course-widget-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #2d2a51;
}

.course-widget-more {
  font-size: 22rpx;
  color: #2444eb;
  font-weight: 600;
}

.course-widget-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.course-widget-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.course-widget-time {
  font-size: 22rpx;
  font-weight: 700;
  color: #75729e;
  width: 88rpx;
  flex-shrink: 0;
}

.course-widget-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 9999rpx;
  flex-shrink: 0;
}

.course-widget-dot--primary   { background-color: #2444eb; }
.course-widget-dot--secondary { background-color: #f97316; }
.course-widget-dot--tertiary  { background-color: #16a34a; }

.course-widget-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #2d2a51;
  flex: 1;
}

.course-widget-room {
  font-size: 22rpx;
  color: #aca8d7;
}

/* ===== 图标快捷功能 ===== */
.shortcut-scroll {
  display: flex;
  flex-direction: row;
  white-space: nowrap;
  padding: 0 32rpx;
  margin-bottom: 12rpx;
}

.shortcut-btn {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 14rpx 20rpx;
  border-radius: 20rpx;
  background-color: #ffffff;
  border: 2rpx solid rgba(172, 168, 215, 0.25);
  margin-right: 14rpx;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(45, 42, 81, 0.05);
}

.shortcut-emoji {
  font-size: 36rpx;
  line-height: 1;
}

.shortcut-label {
  font-size: 20rpx;
  font-weight: 600;
  color: #5a5781;
  white-space: nowrap;
}

/* ===== 聊天滚动区 ===== */
.chat-scroll {
  flex: 1;
  height: 0;
  margin-top: 16rpx;
}

.chat-list {
  padding: 24rpx 32rpx 0;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  width: 100%;
  box-sizing: border-box;
}

/* ===== 消息行 ===== */
.msg-row {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  gap: 16rpx;
}

.msg-row--bot {
  align-self: flex-start;
}

.msg-row--user {
  align-self: flex-end;
  flex-direction: row;
  justify-content: flex-end;
}

.msg-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 9999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.msg-avatar-icon {
  width: 36rpx;
  height: 36rpx;
}

.msg-avatar-photo {
  width: 64rpx;
  height: 64rpx;
  border-radius: 9999rpx;
  display: block;
}

.msg-avatar--bot {
  background-color: #e3dfff;
}

.msg-avatar--user {
  background-color: #2444eb;
}

.msg-bubble {
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  max-width: 460rpx;
  word-break: break-word;
  box-sizing: border-box;
}

.msg-bubble--bot {
  background-color: #f3eeff;
  border-top-left-radius: 0;
}

.msg-bubble--user {
  background-color: #2444eb;
  border-top-right-radius: 0;
  box-shadow: 0 4rpx 8rpx rgba(36, 68, 235, 0.15);
}

.msg-text {
  display: block;
  font-size: 28rpx;
  line-height: 1.6;
  color: #2d2a51;
  word-break: break-all;
  white-space: pre-wrap;
}

.msg-text--bot { color: #2d2a51; }
.msg-text--user { color: #ffffff; }

/* ===== 打字动画 ===== */
.msg-typing {
  opacity: 0.6;
}

.typing-dots {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  background-color: #f3eeff;
  padding: 20rpx 28rpx;
  border-radius: 32rpx;
  border-top-left-radius: 0;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 9999rpx;
  background-color: #2444eb;
  animation: bounce 1s infinite;
}

.dot-2 { animation-delay: 0.15s; }
.dot-3 { animation-delay: 0.3s; }

@keyframes bounce {
  0%, 60%, 100% { transform: translateY(0); }
  30% { transform: translateY(-8rpx); }
}

/* ===== 底部输入区 ===== */
.input-area {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  z-index: 40;
  background: linear-gradient(to top, #f9f5ff 60%, transparent);
  padding-top: 40rpx;
  padding-bottom: env(safe-area-inset-bottom);
  box-sizing: border-box;
}

.quick-scroll {
  display: flex;
  flex-direction: row;
  white-space: nowrap;
  padding: 0 32rpx;
  margin-bottom: 16rpx;
}

.quick-chip {
  display: inline-flex;
  align-items: center;
  margin-right: 16rpx;
  padding: 12rpx 32rpx;
  border-radius: 9999rpx;
  background-color: rgba(221, 217, 255, 0.5);
  border: 2rpx solid rgba(36, 68, 235, 0.1);
  flex-shrink: 0;
}

.quick-chip-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #2444eb;
  white-space: nowrap;
}

.input-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  margin: 0 32rpx 24rpx;
  background-color: #f3eeff;
  border-radius: 9999rpx;
  padding: 16rpx 24rpx;
  border: 2rpx solid rgba(172, 168, 215, 0.2);
  box-shadow: 0 4rpx 8rpx rgba(45, 42, 81, 0.04);
}

.toggle-btn {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background-color: rgba(36, 68, 235, 0.08);
  border-radius: 50%;
}

.toggle-chevron {
  font-size: 36rpx;
  font-weight: 700;
  color: #2444eb;
  line-height: 1;
  display: block;
}

.toggle-chevron--down {
  transform: rotate(-90deg);
}

.toggle-chevron--up {
  transform: rotate(90deg);
}

.plus-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.plus-icon {
  width: 40rpx;
  height: 40rpx;
}

.chat-input {
  flex: 1;
  font-size: 28rpx;
  color: #2d2a51;
  background-color: transparent;
  height: 56rpx;
}

.chat-input-placeholder {
  color: rgba(90, 87, 129, 0.6);
}

.send-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 9999rpx;
  background-color: #2444eb;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.send-icon {
  width: 28rpx;
  height: 28rpx;
}

/* ===== 行程预览按钮（气泡内）===== */
.plan-preview-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  background-color: rgba(36, 68, 235, 0.08);
  border-radius: 14rpx;
  border: 1rpx solid rgba(36, 68, 235, 0.15);
}

.plan-preview-icon {
  font-size: 28rpx;
  line-height: 1;
}

.plan-preview-text {
  flex: 1;
  font-size: 26rpx;
  font-weight: 600;
  color: #2444eb;
}

.plan-preview-arrow {
  font-size: 32rpx;
  color: #2444eb;
  font-weight: 300;
}

/* ===== 行程规划弹窗 ===== */
.plan-modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background-color: rgba(45, 42, 81, 0.5);
  z-index: 9999;
  display: flex;
  align-items: flex-end;
}

.plan-modal-sheet {
  width: 100%;
  background-color: #ffffff;
  border-top-left-radius: 48rpx;
  border-top-right-radius: 48rpx;
  padding: 40rpx 40rpx 48rpx;
  box-sizing: border-box;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  gap: 0;
}

.plan-modal-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  flex-shrink: 0;
}

.plan-modal-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #2d2a51;
}

.plan-modal-x {
  font-size: 30rpx;
  color: #aca8d7;
  padding: 8rpx 12rpx;
}

.plan-modal-scroll {
  flex: 1;
  height: 0;
  overflow: hidden;
}

.plan-summary {
  display: block;
  font-size: 28rpx;
  color: #5a5781;
  line-height: 1.6;
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  background-color: #f3eeff;
  border-radius: 16rpx;
  word-break: break-all;
}

.plan-goal-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 28rpx;
  padding: 20rpx 24rpx;
  background-color: #fff8f0;
  border-radius: 16rpx;
  border-left: 6rpx solid #f97316;
}

.plan-label {
  font-size: 24rpx;
  font-weight: 700;
  color: #5a5781;
}

.plan-goal-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d2a51;
  word-break: break-all;
}

.plan-section {
  margin-bottom: 28rpx;
}

.plan-section-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #5a5781;
  margin-bottom: 16rpx;
}

.plan-time-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0eeff;
}

.plan-time-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 9999rpx;
  background-color: #2444eb;
  flex-shrink: 0;
  margin-top: 8rpx;
}

.plan-time-text {
  font-size: 27rpx;
  color: #2d2a51;
  line-height: 1.6;
  flex: 1;
  word-break: break-all;
}

.plan-step-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 16rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f0eeff;
}

.plan-step-num {
  width: 40rpx;
  height: 40rpx;
  border-radius: 9999rpx;
  background-color: #2444eb;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  text-align: center;
  line-height: 40rpx;
}

.plan-step-text {
  font-size: 27rpx;
  color: #2d2a51;
  line-height: 1.6;
  flex: 1;
  word-break: break-all;
}

.plan-next-row,
.plan-fallback-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 20rpx;
  padding: 20rpx 24rpx;
  background-color: #f0fdf4;
  border-radius: 16rpx;
  border-left: 6rpx solid #22c55e;
}

.plan-next-text {
  font-size: 27rpx;
  color: #2d2a51;
  word-break: break-all;
  line-height: 1.6;
}

.plan-followup-row {
  padding: 16rpx 24rpx;
  background-color: #f9f5ff;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.plan-followup-text {
  font-size: 26rpx;
  color: #75729e;
  line-height: 1.6;
  word-break: break-all;
}

.plan-modal-close-btn {
  margin-top: 24rpx;
  background-color: #f3eeff;
  border-radius: 9999rpx;
  padding: 28rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #5a5781;
  flex-shrink: 0;
}
