.page {
  min-height: 100vh;
  background-color: #f9f5ff;
}

.page-scroll {
  background-color: #f9f5ff;
  width: 100%;
}

.content {
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

/* ===== AI 提醒横幅 ===== */
.ai-banner {
  background: linear-gradient(135deg, #2444eb, #8999ff);
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 16rpx 40rpx rgba(36, 68, 235, 0.1);
}

.ai-banner__body {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.ai-banner__top {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 24rpx;
}

.ai-banner__icon {
  width: 64rpx;
  height: 64rpx;
  flex-shrink: 0;
}

.ai-banner__text {
  flex: 1;
}

.ai-banner__label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 8rpx;
}

.ai-banner__title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.4;
}

.btn-meditation {
  align-self: flex-start;
  background-color: rgba(255, 255, 255, 0.2);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  padding: 16rpx 32rpx;
  border-radius: 9999rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.btn-icon-sm {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.btn-icon-md {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
}

/* ===== 指标行 ===== */
.metrics-row {
  display: flex;
  flex-direction: row;
  gap: 32rpx;
}

/* 健康评分卡 */
.score-card {
  flex: 5;
  background-color: #f3eeff;
  border-radius: 16rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.score-label {
  display: block;
  font-size: 20rpx;
  font-weight: 700;
  color: #5a5781;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
}

.score-canvas-wrap {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.score-canvas {
  width: 160rpx;
  height: 160rpx;
  position: absolute;
  top: 0;
  left: 0;
}

.score-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #2444eb;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  line-height: 1;
}

.score-status {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  margin-top: 16rpx;
}

.score-status-icon {
  width: 24rpx;
  height: 24rpx;
}

.score-status-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #0c6a24;
}

/* 睡眠记录卡 */
.sleep-card {
  flex: 7;
  background-color: #f3eeff;
  border-radius: 16rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.sleep-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.sleep-label {
  font-size: 20rpx;
  font-weight: 700;
  color: #5a5781;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.sleep-value {
  font-size: 24rpx;
  font-weight: 700;
  color: #2444eb;
}

.sleep-bars {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  justify-content: space-between;
  height: 96rpx;
  gap: 8rpx;
}

.sleep-bar {
  flex: 1;
  background-color: rgba(36, 68, 235, 0.2);
  border-top-left-radius: 4rpx;
  border-top-right-radius: 4rpx;
  min-height: 8rpx;
}

.sleep-bar--today {
  background-color: #2444eb;
}

.sleep-note {
  display: block;
  font-size: 18rpx;
  color: #5a5781;
  text-align: right;
  margin-top: 16rpx;
}

/* ===== 情绪历史 ===== */
.section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2d2a51;
  margin-left: 4rpx;
}

.emotion-list {
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
}

.emotion-item {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
}

.emotion-item--bordered {
  border-bottom: 2rpx solid rgba(234, 229, 255, 0.3);
}

.emotion-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
}

.emotion-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 9999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.emotion-icon-wrap--secondary {
  background-color: rgba(255, 198, 151, 0.3);
}

.emotion-icon-wrap--tertiary {
  background-color: rgba(164, 253, 164, 0.3);
}

.emotion-icon-wrap--surface {
  background-color: rgba(221, 217, 255, 0.3);
}

.emotion-icon {
  width: 36rpx;
  height: 36rpx;
}

.emotion-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d2a51;
}

.emotion-time {
  font-size: 22rpx;
  color: #5a5781;
}

/* ===== 打卡按钮 ===== */
.btn-checkin {
  width: 100%;
  background-color: #2444eb;
  color: #ffffff;
  padding: 32rpx;
  border-radius: 9999rpx;
  font-size: 32rpx;
  font-weight: 700;
  box-shadow: 0 16rpx 40rpx rgba(36, 68, 235, 0.2);
  box-sizing: border-box;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.btn-checkin-hover {
  opacity: 0.75;
  transform: scale(0.98);
}

/* ===== 连续打卡横幅 ===== */
.streak-banner {
  background-color: rgba(12, 106, 36, 0.1);
  border: 2rpx solid rgba(12, 106, 36, 0.05);
  border-radius: 9999rpx;
  padding: 24rpx 48rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.streak-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.streak-text {
  font-size: 26rpx;
  font-weight: 700;
  color: #0c6a24;
}

.streak-num {
  font-size: 48rpx;
  font-weight: 900;
  color: #0c6a24;
}

/* ===== 情绪打卡弹窗 ===== */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background-color: rgba(45, 42, 81, 0.6);
  z-index: 9999;
  display: flex;
  align-items: flex-end;
}

.modal-sheet {
  width: 100%;
  background-color: #ffffff;
  border-top-left-radius: 48rpx;
  border-top-right-radius: 48rpx;
  padding: 48rpx 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.modal-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #2d2a51;
  text-align: center;
}

.modal-sub {
  font-size: 26rpx;
  color: #5a5781;
  text-align: center;
  display: block;
  margin-top: -16rpx;
}

.emotion-picker {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 20rpx;
  justify-content: center;
}

.emotion-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 28rpx;
  border-radius: 16rpx;
  background-color: #f3eeff;
  min-width: 120rpx;
}

.emotion-option--active {
  background-color: #2444eb;
}

.emotion-emoji {
  font-size: 48rpx;
}

.emotion-name {
  font-size: 22rpx;
  font-weight: 600;
  color: #5a5781;
}

.emotion-option--active .emotion-name {
  color: #ffffff;
}

.modal-confirm {
  background-color: #2444eb;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  padding: 28rpx;
  border-radius: 9999rpx;
  text-align: center;
  box-shadow: 0 8rpx 20rpx rgba(36, 68, 235, 0.2);
}

/* ===== 冥想计时器弹窗 ===== */
.meditation-sheet {
  width: 100%;
  background: linear-gradient(160deg, #2444eb, #8999ff);
  border-top-left-radius: 48rpx;
  border-top-right-radius: 48rpx;
  padding: 64rpx 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 40rpx;
}

.meditation-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #ffffff;
  text-align: center;
}

.meditation-timer {
  font-size: 120rpx;
  font-weight: 900;
  color: #ffffff;
  letter-spacing: -4rpx;
  line-height: 1;
}

.meditation-sub {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
  text-align: center;
}

.meditation-duration-row {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}

.duration-chip {
  padding: 12rpx 36rpx;
  border-radius: 9999rpx;
  background-color: rgba(255,255,255,0.2);
  font-size: 26rpx;
  font-weight: 700;
  color: rgba(255,255,255,0.8);
}

.duration-chip--active {
  background-color: #ffffff;
  color: #2444eb;
}

.meditation-actions {
  display: flex;
  flex-direction: row;
  gap: 24rpx;
  width: 100%;
}

.btn-med-cancel {
  flex: 1;
  background-color: rgba(255,255,255,0.2);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  padding: 28rpx;
  border-radius: 9999rpx;
  text-align: center;
}

.btn-med-action {
  flex: 2;
  background-color: #ffffff;
  color: #2444eb;
  font-size: 28rpx;
  font-weight: 700;
  padding: 28rpx;
  border-radius: 9999rpx;
  text-align: center;
}
